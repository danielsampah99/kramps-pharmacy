{
	"name": "kramps-pharmacy",
	"private": true,
	"type": "module",
	"sideEffects": false,
	"scripts": {
		"dev": "convex dev --start 'vite dev --port 4000 --host pharmacy.localhost'",
		"build": "vite build && tsc --noEmit",
		"start": "node .output/server/index.mjs",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix"
	},
	"dependencies": {
		"@auth/core": "0.41.1",
		"@cloudflare/kumo": "^2.6.0",
		"@convex-dev/auth": "^0.0.94",
		"@convex-dev/react-query": "^0.1.0",
		"@solar-icons/react": "^1.1.1",
		"@tanstack/react-form": "^1.33.0",
		"@tanstack/react-query": "^5.99.0",
		"@tanstack/react-router": "^1.168.22",
		"@tanstack/react-router-with-query": "^1.130.17",
		"@tanstack/react-start": "^1.167.41",
		"@tanstack/react-store": "^0.11.0",
		"@tanstack/react-table": "9.0.0-beta.21",
		"@unpic/react": "^1.0.2",
		"convex": "^1.36.1",
		"date-fns": "^4.4.0",
		"jose": "^6.2.3",
		"nitro": "3.0.260610-beta",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"svrx": "^0.0.10"
	},
	"devDependencies": {
		"@convex-dev/eslint-plugin": "^2.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/devtools-vite": "^0.8.0",
		"@tanstack/eslint-config": "^0.4.0",
		"@tanstack/react-devtools": "^0.10.7",
		"@tanstack/react-form-devtools": "^0.2.29",
		"@tanstack/react-query-devtools": "^5.101.0",
		"@tanstack/react-router-devtools": "^1.167.0",
		"@tanstack/react-table-devtools": "9.0.0-beta.21",
		"@types/node": "^26.0.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"oxfmt": "^0.56.0",
		"oxlint": "^1.71.0",
		"oxlint-tsgolint": "^0.23.0",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.3",
		"vite": "^8.1.0"
	},
	"engines": {
		"packageManager": "pnpm@10"
	},
	"packageManager": "pnpm@10.27.0",
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"@tailwindcss/oxide"
		],
		"peerDependencyRules": {
			"allowedVersions": {
				"tsconfck": "6.0.3"
			}
		},
		"overrides": {
			"vite": "^8"
		}
	}
}
